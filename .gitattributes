# Auto normalize the text files
* text=auto

# Force LF for source code (for cross-platform/computers)
*.c   text eol=lf
*.cpp text eol=lf
*.h   text eol=lf
*.hpp text eol=lf
*.ino text eol=lf

# Shell scripts must be LF (Linux)
*.sh  text eol=lf

# Windows scripts
*.bat text eol=crlf

# Binary files (never modify)
*.png binary
*.jpg binary
*.bin binary
